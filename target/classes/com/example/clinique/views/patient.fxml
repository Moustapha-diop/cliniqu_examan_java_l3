<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="565.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.clinique.controller.PatientController"
            styleClass="root-pane">

   <children>
      <!-- Formulaire gauche -->
      <Label layoutX="20.0" layoutY="10.0" text="Nom *" styleClass="form-label"/>
      <TextField fx:id="nom" layoutX="20.0" layoutY="30.0" prefWidth="180.0" styleClass="form-input"/>

      <Label layoutX="20.0" layoutY="62.0" text="Prénom *" styleClass="form-label"/>
      <TextField fx:id="prenom" layoutX="20.0" layoutY="82.0" prefWidth="180.0" styleClass="form-input"/>

      <Label layoutX="20.0" layoutY="114.0" text="Date de naissance *" styleClass="form-label"/>
      <DatePicker fx:id="dateNaissance" layoutX="20.0" layoutY="134.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="166.0" text="Sexe *" styleClass="form-label"/>
      <ComboBox fx:id="sexe" layoutX="20.0" layoutY="186.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="218.0" text="Téléphone *" styleClass="form-label"/>
      <TextField fx:id="telephone" layoutX="20.0" layoutY="238.0" prefWidth="180.0" styleClass="form-input"/>

      <Label layoutX="20.0" layoutY="270.0" text="Adresse" styleClass="form-label"/>
      <TextField fx:id="adresse" layoutX="20.0" layoutY="290.0" prefWidth="180.0" styleClass="form-input"/>

      <Label layoutX="20.0" layoutY="322.0" text="Groupe sanguin" styleClass="form-label"/>
      <ComboBox fx:id="groupeSanguin" layoutX="20.0" layoutY="342.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="374.0" text="Antécédents médicaux" styleClass="form-label"/>
      <TextArea fx:id="antecedents" layoutX="20.0" layoutY="394.0" prefWidth="180.0" prefHeight="70.0" styleClass="form-textarea"/>

      <Label fx:id="lblTitre" layoutX="20.0" layoutY="474.0" text="Nouveau Patient" styleClass="panel-title"/>
      <Button layoutX="20.0" layoutY="500.0" mnemonicParsing="false" onAction="#addPatient" text="Enregistrer" styleClass="btn-primary" prefWidth="85.0"/>
      <Button fx:id="btnSupprimer" layoutX="115.0" layoutY="500.0" mnemonicParsing="false" onAction="#deletePatient" text="Supprimer" styleClass="btn-danger" prefWidth="85.0"/>

      <!-- Tableau droite -->
      <Label layoutX="215.0" layoutY="10.0" text="🔍 Rechercher" styleClass="form-label"/>
      <TextField fx:id="txtSearch" layoutX="215.0" layoutY="30.0" prefWidth="765.0" styleClass="search-field"/>

      <TableView fx:id="tablePatients" layoutX="215.0" layoutY="62.0" prefHeight="490.0" prefWidth="765.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="colNom" prefWidth="120.0" text="Nom" />
          <TableColumn fx:id="colPrenom" prefWidth="120.0" text="Prénom" />
          <TableColumn fx:id="colDateNaissance" prefWidth="100.0" text="Naissance" />
          <TableColumn fx:id="colSexe" prefWidth="70.0" text="Sexe" />
          <TableColumn fx:id="colTelephone" prefWidth="110.0" text="Téléphone" />
          <TableColumn fx:id="colGroupeSanguin" prefWidth="70.0" text="Groupe" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
