<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="565.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.clinique.controller.ConsultationController"
            styleClass="root-pane">
   <children>
      <Label layoutX="20.0" layoutY="10.0" text="Patient *" styleClass="form-label"/>
      <ComboBox fx:id="cmbPatient" layoutX="20.0" layoutY="30.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="62.0" text="Médecin *" styleClass="form-label"/>
      <ComboBox fx:id="cmbMedecin" layoutX="20.0" layoutY="82.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="114.0" text="Rendez-vous associé" styleClass="form-label"/>
      <ComboBox fx:id="cmbRendezVous" layoutX="20.0" layoutY="134.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="166.0" text="Diagnostic *" styleClass="form-label"/>
      <TextArea fx:id="txtDiagnostic" layoutX="20.0" layoutY="186.0" prefWidth="180.0" prefHeight="70.0" styleClass="form-textarea"/>

      <Label layoutX="20.0" layoutY="265.0" text="Observations" styleClass="form-label"/>
      <TextArea fx:id="txtObservations" layoutX="20.0" layoutY="285.0" prefWidth="180.0" prefHeight="70.0" styleClass="form-textarea"/>

      <Label layoutX="20.0" layoutY="364.0" text="Prescription" styleClass="form-label"/>
      <TextArea fx:id="txtPrescription" layoutX="20.0" layoutY="384.0" prefWidth="180.0" prefHeight="70.0" styleClass="form-textarea"/>

      <Label fx:id="lblTitre" layoutX="20.0" layoutY="464.0" text="Nouvelle Consultation" styleClass="panel-title"/>
      <Button layoutX="20.0" layoutY="490.0" text="Enregistrer" onAction="#addConsultation" styleClass="btn-primary" prefWidth="180.0"/>
      <Button layoutX="20.0" layoutY="528.0" text="📄 Générer Ordonnance PDF" onAction="#genererOrdonnance" styleClass="btn-secondary" prefWidth="180.0"/>

      <TableView fx:id="tableConsultations" layoutX="215.0" layoutY="10.0" prefHeight="545.0" prefWidth="765.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="45.0" text="ID" />
          <TableColumn fx:id="colPatient" prefWidth="150.0" text="Patient" />
          <TableColumn fx:id="colMedecin" prefWidth="150.0" text="Médecin" />
          <TableColumn fx:id="colDate" prefWidth="130.0" text="Date" />
          <TableColumn fx:id="colDiagnostic" prefWidth="270.0" text="Diagnostic" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
