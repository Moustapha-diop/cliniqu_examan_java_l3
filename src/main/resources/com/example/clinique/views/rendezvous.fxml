<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="565.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.clinique.controller.RendezVousController"
            styleClass="root-pane">
   <children>
      <Label layoutX="20.0" layoutY="10.0" text="Patient *" styleClass="form-label"/>
      <ComboBox fx:id="cmbPatient" layoutX="20.0" layoutY="30.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="62.0" text="Médecin *" styleClass="form-label"/>
      <ComboBox fx:id="cmbMedecin" layoutX="20.0" layoutY="82.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="114.0" text="Date *" styleClass="form-label"/>
      <DatePicker fx:id="dpDate" layoutX="20.0" layoutY="134.0" prefWidth="180.0"/>

      <Label layoutX="20.0" layoutY="166.0" text="Heure (HH:mm) *" styleClass="form-label"/>
      <TextField fx:id="txtHeure" layoutX="20.0" layoutY="186.0" prefWidth="180.0" promptText="09:00" styleClass="form-input"/>

      <Label layoutX="20.0" layoutY="218.0" text="Motif" styleClass="form-label"/>
      <TextArea fx:id="txtMotif" layoutX="20.0" layoutY="238.0" prefWidth="180.0" prefHeight="60.0" styleClass="form-textarea"/>

      <Label layoutX="20.0" layoutY="308.0" text="Statut" styleClass="form-label"/>
      <ComboBox fx:id="cmbStatut" layoutX="20.0" layoutY="328.0" prefWidth="180.0"/>

      <!-- Filtres -->
      <Label layoutX="20.0" layoutY="375.0" text="─── Filtres ───" styleClass="form-label"/>
      <DatePicker fx:id="dpFiltreDate" layoutX="20.0" layoutY="398.0" prefWidth="180.0"/>
      <Button layoutX="20.0" layoutY="432.0" text="Par date" onAction="#filtrerParDate" styleClass="btn-secondary" prefWidth="85.0"/>
      <Button layoutX="115.0" layoutY="432.0" text="Aujourd'hui" onAction="#filtrerAujourdhui" styleClass="btn-secondary" prefWidth="85.0"/>
      <ComboBox fx:id="cmbFiltreMedecin" layoutX="20.0" layoutY="462.0" prefWidth="180.0"/>
      <Button layoutX="20.0" layoutY="496.0" text="Par médecin" onAction="#filtrerParMedecin" styleClass="btn-secondary" prefWidth="85.0"/>
      <Button layoutX="115.0" layoutY="496.0" text="Tous" onAction="#reinitialiserFiltres" styleClass="btn-secondary" prefWidth="85.0"/>

      <Label fx:id="lblTitre" layoutX="20.0" layoutY="530.0" text="Nouveau RDV" styleClass="panel-title"/>

      <TableView fx:id="tableRdv" layoutX="215.0" layoutY="10.0" prefHeight="490.0" prefWidth="765.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="45.0" text="ID" />
          <TableColumn fx:id="colPatient" prefWidth="140.0" text="Patient" />
          <TableColumn fx:id="colMedecin" prefWidth="140.0" text="Médecin" />
          <TableColumn fx:id="colDate" prefWidth="130.0" text="Date/Heure" />
          <TableColumn fx:id="colMotif" prefWidth="130.0" text="Motif" />
          <TableColumn fx:id="colStatut" prefWidth="100.0" text="Statut" />
        </columns>
      </TableView>

      <HBox layoutX="215.0" layoutY="510.0" spacing="10">
        <Button text="Enregistrer" onAction="#addRendezVous" styleClass="btn-primary" prefWidth="120.0"/>
        <Button fx:id="btnSupprimer" text="Annuler RDV" onAction="#annulerRdv" styleClass="btn-danger" prefWidth="120.0"/>
        <Button text="Nouveau" onAction="#nouveauRdv" styleClass="btn-secondary" prefWidth="100.0"/>
      </HBox>
   </children>
</AnchorPane>
