<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.clinique.controller.LoginController"
           prefWidth="900" prefHeight="600"
           styleClass="root-pane">

    <VBox alignment="CENTER" spacing="0" maxWidth="400" styleClass="login-card">

        <VBox styleClass="login-header" alignment="CENTER" spacing="8">
            <Text text="" style="-fx-font-size: 44px;"/>
            <Label text="Clinique Médicale" styleClass="login-title"/>
            <Label text="Système de Gestion" styleClass="login-subtitle"/>
        </VBox>

        <VBox styleClass="login-form" spacing="16">
            <VBox spacing="5">
                <Label text="Nom d'utilisateur" styleClass="form-label"/>
                <TextField fx:id="txtUsername" promptText="Entrez votre identifiant" styleClass="form-input"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Mot de passe" styleClass="form-label"/>
                <PasswordField fx:id="txtPassword" promptText="Entrez votre mot de passe" styleClass="form-input"/>
            </VBox>
            <Label fx:id="lblErreur" styleClass="error-label" wrapText="true"/>
            <Button text="SE CONNECTER" styleClass="btn-primary" maxWidth="Infinity" onAction="#Login"/>
        </VBox>

    </VBox>
</StackPane>
