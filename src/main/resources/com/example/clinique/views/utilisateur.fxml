<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane prefHeight="580.0" prefWidth="960.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.clinique.controller.UtilisateurController">

    <VBox spacing="14" AnchorPane.topAnchor="16" AnchorPane.leftAnchor="16"
          AnchorPane.rightAnchor="16" AnchorPane.bottomAnchor="16">

        <Label text="👥  Gestion des Utilisateurs" style="-fx-font-size:18px; -fx-font-weight:bold;"/>

        <!-- Tableau -->
        <TableView fx:id="tableUtilisateurs" prefHeight="240">
            <columns>
                <TableColumn fx:id="colId"       text="ID"         prefWidth="50"/>
                <TableColumn fx:id="colUsername"  text="Username"   prefWidth="140"/>
                <TableColumn fx:id="colNom"       text="Nom"        prefWidth="140"/>
                <TableColumn fx:id="colPrenom"    text="Prénom"     prefWidth="140"/>
                <TableColumn fx:id="colRole"      text="Rôle"       prefWidth="150"/>
                <TableColumn fx:id="colActif"     text="Statut"     prefWidth="100"/>
            </columns>
            <placeholder><Label text="Aucun utilisateur"/></placeholder>
        </TableView>

        <!-- Formulaire création -->
        <TitledPane text="➕  Créer un nouvel utilisateur" expanded="true">
            <GridPane hgap="12" vgap="10">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <Label text="Username :"      GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="txtUsername" promptText="ex: dr.dupont"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="180"/>

                <Label text="Mot de passe :" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <PasswordField fx:id="txtPassword" promptText="min. 4 caractères"
                               GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="180"/>

                <Label text="Nom :"          GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="txtNom"    promptText="Nom de famille"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="180"/>

                <Label text="Prénom :"       GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="txtPrenom" promptText="Prénom"
                           GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="180"/>

                <Label text="Rôle :"         GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="cmbRole"    GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="180"/>

                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.columnSpan="3">
                    <Button text="✅ Créer"   onAction="#Ajouter"
                            style="-fx-background-color:#1a78c2; -fx-text-fill:white; -fx-font-weight:bold;"/>
                    <Button text="🔄 Nouveau" onAction="#NouveauFormulaire"
                            style="-fx-background-color:#888; -fx-text-fill:white;"/>
                </HBox>
            </GridPane>
        </TitledPane>

        <!-- Actions sur utilisateur sélectionné -->
        <TitledPane text="⚙️  Actions sur l'utilisateur sélectionné" expanded="true">
            <HBox spacing="16" alignment="CENTER_LEFT">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <Button text="🔛 Activer / Désactiver" onAction="#ToggleActif"
                        style="-fx-background-color:#f0a500; -fx-text-fill:white; -fx-font-weight:bold;"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Nouveau mot de passe :"/>
                <PasswordField fx:id="txtNouveauMdp" promptText="Nouveau mdp" prefWidth="160"/>
                <Button text="🔑 Réinitialiser" onAction="#ReinitialiserMdp"
                        style="-fx-background-color:#005aa0; -fx-text-fill:white; -fx-font-weight:bold;"/>

                <Separator orientation="VERTICAL"/>

                <Button text="🗑️ Supprimer" onAction="#Supprimer"
                        style="-fx-background-color:#c0392b; -fx-text-fill:white; -fx-font-weight:bold;"/>
            </HBox>
        </TitledPane>

    </VBox>
</AnchorPane>
